generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum PlanType {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INACTIVE
}

enum DrawStatus {
  DRAFT
  SIMULATED
  PUBLISHED
}

enum DrawLogic {
  RANDOM
  WEIGHTED
}

enum PayoutStatus {
  PENDING
  PAID
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  UPDATE
  DRAW_RESULT
  WINNER_ALERT
}

enum DonationSource {
  SUBSCRIPTION
  DIRECT
}

model User {
  id                  String         @id @default(cuid())
  name                String
  email               String         @unique
  passwordHash        String
  role                UserRole       @default(USER)
  selectedCharityId   String?
  contributionPercent Int            @default(10)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  selectedCharity     Charity?       @relation(fields: [selectedCharityId], references: [id])
  subscriptions       Subscription[]
  scores              ScoreEntry[]
  tickets             DrawTicket[]
  wins                DrawWinner[]
  donations           Donation[]
  notifications       Notification[]
}

model Charity {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String
  imageUrl    String
  events      Json?
  featured    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  users       User[]
  donations   Donation[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  plan                 PlanType
  status               SubscriptionStatus @default(INACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  amountCents          Int
  currentPeriodEnd     DateTime?
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoreEntry {
  id        String   @id @default(cuid())
  userId    String
  score     Int
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Draw {
  id                String      @id @default(cuid())
  month             Int
  year              Int
  status            DrawStatus  @default(DRAFT)
  logic             DrawLogic
  numbers           Int[]
  simulationNumbers Int[]
  jackpotCarryCents Int         @default(0)
  publishedAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  tickets           DrawTicket[]
  winners           DrawWinner[]

  @@unique([month, year])
}

model DrawTicket {
  id        String   @id @default(cuid())
  drawId    String
  userId    String
  numbers   Int[]
  createdAt DateTime @default(now())

  draw      Draw     @relation(fields: [drawId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([drawId, userId])
}

model DrawWinner {
  id                 String             @id @default(cuid())
  drawId             String
  userId             String
  matchCount         Int
  amountCents        Int
  payoutStatus       PayoutStatus       @default(PENDING)
  verificationStatus VerificationStatus @default(PENDING)
  proofUrl           String?
  reviewedAt         DateTime?
  paidAt             DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  draw               Draw               @relation(fields: [drawId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([drawId, matchCount])
}

model MonthlyPool {
  id                  String   @id @default(cuid())
  month               Int
  year                Int
  activeSubscribers   Int
  totalPoolCents      Int
  fiveMatchPoolCents  Int
  fourMatchPoolCents  Int
  threeMatchPoolCents Int
  rolloverCents       Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([month, year])
}

model Donation {
  id          String         @id @default(cuid())
  userId      String?
  charityId   String
  amountCents Int
  source      DonationSource
  createdAt   DateTime       @default(now())

  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  charity     Charity        @relation(fields: [charityId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}
